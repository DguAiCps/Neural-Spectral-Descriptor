CLAUDE.md

# Bundled checkpoints (paper reproduction) — keep tracked despite *.pth above
# Pattern: un-ignore directory, re-ignore contents, then un-ignore specific file
!results/ctx128_cosine_bayesian/
results/ctx128_cosine_bayesian/*
!results/ctx128_cosine_bayesian/best_model.pth
!baselines/weights/
baselines/weights/*
!baselines/weights/bevplace_finetune.pth

# _ablation: encoder-preset + gated GAT + phase rerank ablation tree
# Skip transient / derived data (preprocessed caches, logs, intermediate ckpts)
_ablation/data/
_ablation/logs/
_ablation/results/*/checkpoint_epoch_*.pth
_ablation/results/*/final_model.pth
_ablation/results/*/similarity_dist.npz
# Keep the multi-sensor ablation best checkpoint (paper-reproducible)
!_ablation/results/ablation_no_interdiff_gate_seed42/
_ablation/results/ablation_no_interdiff_gate_seed42/*
!_ablation/results/ablation_no_interdiff_gate_seed42/best_model.pth
# Keep professor's handoff checkpoints (KITTI-only baselines, ~4 MB total)
!_ablation/_handoff/
